# HTTP-заголовки безопасности для Cloudflare (static assets).
# Синтаксис: https://developers.cloudflare.com/pages/configuration/headers/
# Сайт полностью статический, поэтому это основная мера защиты на стороне ответа.

/*
  # Запрет угадывания MIME-типа (защита от ряда XSS через подмену типа).
  X-Content-Type-Options: nosniff
  # Запрет встраивания в чужие iframe (защита от clickjacking).
  X-Frame-Options: SAMEORIGIN
  # Не утекать полный URL реферера на внешние сайты.
  Referrer-Policy: strict-origin-when-cross-origin
  # Отключаем неиспользуемые браузерные API.
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  # Принудительный HTTPS (HSTS) на 1 год, включая поддомены.
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  # Запрет встраивания как ресурс с других origin.
  Cross-Origin-Opener-Policy: same-origin

# Хешированные ассеты Astro неизменяемы — кешируем надолго.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
