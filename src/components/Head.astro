---
// Переопределение стандартного <Head> Starlight.
// Рендерит дефолтный head (с пробросом всех props маршрута) и добавляет
// клиентский рендер Mermaid-диаграмм: rehype-mermaid в режиме pre-mermaid
// оставляет <pre class="mermaid">, а рендер делаем здесь, в браузере.
// mermaid (~600 КБ) грузится лениво — только на страницах с диаграммами.
import Default from '@astrojs/starlight/components/Head.astro';
import type { Props } from '@astrojs/starlight/props';

const props = Astro.props as Props;
---

<Default {...props} />

<script>
  type Diagram = { el: HTMLElement; code: string; id: string };

  // Список диаграмм текущей страницы. Перезаписываем только когда реально
  // нашли <pre class="mermaid"> — иначе повторный вызов setup() (например,
  // от astro:page-load на той же странице) очистил бы список.
  let diagrams: Diagram[] = [];
  let mermaidPromise: Promise<typeof import('mermaid').default> | null = null;
  // Цепочка промисов: рендеры не накладываются друг на друга и не теряются
  // (важно, когда смена темы прилетает прямо во время первого рендера).
  let renderChain: Promise<void> = Promise.resolve();

  function loadMermaid() {
    if (!mermaidPromise) {
      mermaidPromise = import('mermaid').then((m) => m.default);
    }
    return mermaidPromise;
  }

  function currentTheme(): 'default' | 'dark' {
    return document.documentElement.dataset.theme === 'light' ? 'default' : 'dark';
  }

  async function render() {
    if (diagrams.length === 0) return;
    const mermaid = await loadMermaid();
    // Ждём шрифты: иначе mermaid измеряет текст не тем шрифтом и может выдать
    // битую/пустую разметку на первом рендере.
    if (document.fonts?.ready) {
      try {
        await document.fonts.ready;
      } catch {
        /* не критично */
      }
    }
    mermaid.initialize({
      startOnLoad: false,
      theme: currentTheme(),
      // Конкретный системный шрифт, а не 'inherit' — не зависим от загрузки
      // веб-шрифтов и от их метрик.
      fontFamily: 'system-ui, -apple-system, Segoe UI, sans-serif',
      securityLevel: 'strict',
    });
    for (const d of diagrams) {
      try {
        const { svg } = await mermaid.render(d.id, d.code);
        d.el.innerHTML = svg;
      } catch (err) {
        console.error('Mermaid render error:', err);
        d.el.textContent = d.code;
      }
    }
  }

  // Сериализуем рендеры через цепочку промисов.
  function scheduleRender() {
    renderChain = renderChain.then(render).catch((e) => console.error(e));
  }

  // Заменяем каждый <pre class="mermaid"> на контейнер, запоминая исходник.
  function setup() {
    const blocks = document.querySelectorAll<HTMLElement>('pre.mermaid');
    if (blocks.length === 0) return; // нечего рендерить — список не трогаем
    diagrams = [];
    blocks.forEach((pre, i) => {
      const code = pre.textContent ?? '';
      const container = document.createElement('div');
      container.className = 'mermaid-diagram';
      pre.replaceWith(container);
      diagrams.push({ el: container, code, id: `mermaid-${Date.now()}-${i}` });
    });
    scheduleRender();
  }

  // Первичная инициализация (модульный скрипт выполняется после парсинга DOM).
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup, { once: true });
  } else {
    setup();
  }

  // Навигация при включённых view-transitions.
  document.addEventListener('astro:page-load', setup);

  // Подстраховка: если к полной загрузке svg так и не появился — дорисуем.
  window.addEventListener('load', () => {
    if (diagrams.length && !document.querySelector('.mermaid-diagram svg')) {
      scheduleRender();
    }
  });

  // Перерисовка при переключении светлой/тёмной темы.
  new MutationObserver((mutations) => {
    if (mutations.some((m) => m.attributeName === 'data-theme')) scheduleRender();
  }).observe(document.documentElement, { attributes: true });
</script>

<script>
  // GitHub-ссылки (иконка в шапке от Starlight) открываем в новой вкладке.
  function externalizeGithub() {
    document
      .querySelectorAll<HTMLAnchorElement>('a[href*="github.com"]:not([target])')
      .forEach((a) => {
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
      });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', externalizeGithub, { once: true });
  } else {
    externalizeGithub();
  }
  document.addEventListener('astro:page-load', externalizeGithub);
</script>
