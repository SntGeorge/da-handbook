---
// Переопределение стандартного <Head> Starlight.
// Рендерит дефолтный head (с пробросом всех props маршрута) и добавляет
// клиентский рендер Mermaid-диаграмм: rehype-mermaid в режиме pre-mermaid
// оставляет <pre class="mermaid">, а рендер делаем здесь, в браузере.
// mermaid (~600 КБ) грузится лениво — только на страницах с диаграммами.
import Default from '@astrojs/starlight/components/Head.astro';
import type { Props } from '@astrojs/starlight/props';

const props = Astro.props as Props;
---

<Default {...props} />

<script>
  type Diagram = { el: HTMLElement; code: string; id: string };

  // Список диаграмм текущей страницы. ВАЖНО: перезаписываем его только когда
  // реально нашли <pre class="mermaid"> — иначе повторный вызов setup()
  // (например, от astro:page-load на той же странице) очистил бы список и
  // первый рендер ушёл бы «в пустоту». Это и был баг с пропадающей схемой.
  let diagrams: Diagram[] = [];
  let mermaidPromise: Promise<typeof import('mermaid').default> | null = null;

  function loadMermaid() {
    if (!mermaidPromise) {
      mermaidPromise = import('mermaid').then((m) => m.default);
    }
    return mermaidPromise;
  }

  function currentTheme(): 'default' | 'dark' {
    // data-theme может быть 'light' | 'dark'; при 'auto' Starlight всё равно
    // проставляет конкретное значение. Нет значения — считаем тёмной.
    return document.documentElement.dataset.theme === 'light' ? 'default' : 'dark';
  }

  async function render() {
    if (diagrams.length === 0) return;
    const mermaid = await loadMermaid();
    mermaid.initialize({
      startOnLoad: false,
      theme: currentTheme(),
      fontFamily: 'inherit',
      securityLevel: 'strict',
    });
    await Promise.all(
      diagrams.map(async (d) => {
        try {
          const { svg } = await mermaid.render(d.id, d.code);
          d.el.innerHTML = svg;
        } catch (err) {
          console.error('Mermaid render error:', err);
          d.el.textContent = d.code;
        }
      })
    );
  }

  // Заменяем каждый <pre class="mermaid"> на контейнер, запоминая исходник.
  function setup() {
    const blocks = document.querySelectorAll<HTMLElement>('pre.mermaid');
    if (blocks.length === 0) return; // ничего нового — список не трогаем
    diagrams = [];
    blocks.forEach((pre, i) => {
      const code = pre.textContent ?? '';
      const container = document.createElement('div');
      container.className = 'mermaid-diagram';
      pre.replaceWith(container);
      diagrams.push({ el: container, code, id: `mermaid-${Date.now()}-${i}` });
    });
    render();
  }

  // Первичная инициализация (модульный скрипт выполняется после парсинга DOM).
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup, { once: true });
  } else {
    setup();
  }

  // Навигация при включённых view-transitions.
  document.addEventListener('astro:page-load', setup);

  // Перерисовка при переключении светлой/тёмной темы (без повторного collect).
  new MutationObserver((mutations) => {
    if (mutations.some((m) => m.attributeName === 'data-theme')) render();
  }).observe(document.documentElement, { attributes: true });
</script>
